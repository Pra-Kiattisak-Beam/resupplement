<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RE LIVTOX - อาหารเสริมแก้แฮงค์และบำรุงตับ</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;600;700&display=swap');
        body {
            font-family: 'Prompt', sans-serif;
            scroll-behavior: smooth;
        }
    </style>
</head>
<body class="bg-gray-50 text-gray-800">

    <nav class="bg-red-600 text-white fixed w-full z-50 shadow-md">
        <div class="container mx-auto px-6 py-4 flex justify-between items-center">
            <a href="#" class="text-3xl font-bold tracking-wider">RE <span class="text-sm font-light">LIVTOX</span></a>
            <div class="space-x-6 hidden md:flex items-center">
                <a href="#about" class="hover:text-red-200">เกี่ยวกับเรา</a>
                <a href="#ingredients" class="hover:text-red-200">ส่วนผสม</a>
                <a href="#shop" class="hover:text-red-200">สั่งซื้อสินค้า</a>
                <button onclick="toggleCart()" class="bg-white text-red-600 px-4 py-2 rounded-full font-semibold hover:bg-gray-100 transition">
                    🛒 ตะกร้า (<span id="cart-count">0</span>)
                </button>
            </div>
            <button onclick="toggleCart()" class="md:hidden bg-white text-red-600 px-3 py-1 rounded-full font-semibold">
                🛒 (<span id="cart-count-mobile">0</span>)
            </button>
        </div>
    </nav>

    <header class="pt-28 pb-20 bg-gradient-to-b from-red-50 to-white">
        <div class="container mx-auto px-6 flex flex-col md:flex-row items-center">
            <div class="md:w-1/2 mt-10 md:mt-0 text-center md:text-left">
                <h1 class="text-4xl md:text-6xl font-bold text-gray-900 leading-tight mb-4">
                    RESET <br> RESTART <br> <span class="text-red-600">RECOVER</span>
                </h1>
                <p class="text-xl text-gray-600 mb-8">
                    ดื่มหนักแค่ไหนเช้ามา ไปทำงานได้ปกติ คอแข็ง ไม่มีแฮงค์ อาหารเสริมช่วยบำรุงตับและขับสารพิษ
                </p>
                <a href="#shop" class="bg-red-600 text-white px-8 py-4 rounded-full text-lg font-bold hover:bg-red-700 transition shadow-lg">
                    สั่งซื้อเลยตอนนี้
                </a>
            </div>
            <div class="md:w-1/2 flex justify-center mt-12 md:mt-0">
                <div class="bg-red-100 w-64 h-80 rounded-xl flex items-center justify-center text-red-400 border-4 border-red-200 shadow-xl">
                    <span class="text-xl font-semibold">[ รูปภาพสินค้า RE LIVTOX ]</span>
                </div>
            </div>
        </div>
    </header>

    <section id="about" class="py-20 bg-white">
        <div class="container mx-auto px-6">
            <h2 class="text-3xl font-bold text-center mb-12">ทำไมต้องเลือก RE LIVTOX?</h2>
            <div class="grid md:grid-cols-3 gap-10">
                <div class="text-center p-6 bg-gray-50 rounded-lg shadow-sm">
                    <div class="text-4xl mb-4">🚀</div>
                    <h3 class="text-xl font-bold mb-2 text-red-600">ฟื้นฟูอย่างรวดเร็ว</h3>
                    <p class="text-gray-600">ลดอาการปวดหัว คลื่นไส้ อ่อนเพลีย คืนความสดชื่นและพลังงานให้พร้อมลุยงานต่อ</p>
                </div>
                <div class="text-center p-6 bg-gray-50 rounded-lg shadow-sm">
                    <div class="text-4xl mb-4">🛡️</div>
                    <h3 class="text-xl font-bold mb-2 text-red-600">บำรุงและปกป้องตับ</h3>
                    <p class="text-gray-600">ช่วยตับในการกำจัดสารพิษที่เกิดจากการดื่มแอลกอฮอล์ ดูแลสุขภาพระยะยาว</p>
                </div>
                <div class="text-center p-6 bg-gray-50 rounded-lg shadow-sm">
                    <div class="text-4xl mb-4">🌿</div>
                    <h3 class="text-xl font-bold mb-2 text-red-600">สารสกัดธรรมชาติ 11 ชนิด</h3>
                    <p class="text-gray-600">สูตรธรรมชาติ ปลอดภัย พรีเมียม ไม่มีสารเคมีอันตราย มาตรฐาน อย. และ GMP</p>
                </div>
            </div>
        </div>
    </section>

    <section id="shop" class="py-20 bg-gray-900 text-white">
        <div class="container mx-auto px-6">
            <h2 class="text-3xl font-bold text-center mb-12">เลือกซื้อสินค้า</h2>
            <div class="max-w-sm mx-auto bg-white text-gray-800 rounded-2xl overflow-hidden shadow-2xl transform hover:scale-105 transition duration-300">
                <div class="h-48 bg-red-100 flex items-center justify-center">
                    <span class="text-red-400 font-bold">[ รูปซอง RE LIVTOX ]</span>
                </div>
                <div class="p-6">
                    <div class="flex justify-between items-center mb-2">
                        <h3 class="text-2xl font-bold">RE LIVTOX</h3>
                        <span class="bg-red-100 text-red-800 text-xs px-2 py-1 rounded-full font-semibold">ขายดี</span>
                    </div>
                    <p class="text-gray-500 mb-4">1 ซอง (บรรจุ 2 แคปซูล) พกพาง่าย ทานสะดวก</p>
                    <div class="flex justify-between items-center mt-6">
                        <span class="text-3xl font-bold text-red-600">฿69</span>
                        <button onclick="addToCart(1, 'RE LIVTOX (1 ซอง)', 69)" class="bg-gray-900 text-white px-4 py-2 rounded-lg font-bold hover:bg-red-600 transition">
                            ใส่ตะกร้า
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <footer class="bg-gray-100 py-8 text-center text-gray-500">
        <p>&copy; 2026 RE LIVTOX. All rights reserved.</p>
    </footer>

    <div id="cart-modal" class="fixed inset-0 bg-black bg-opacity-50 hidden z-50 flex justify-end">
        <div class="bg-white w-full md:w-96 h-full shadow-2xl flex flex-col">
            <div class="p-6 border-b flex justify-between items-center bg-gray-50">
                <h2 class="text-2xl font-bold">ตะกร้าสินค้า</h2>
                <button onclick="toggleCart()" class="text-gray-500 hover:text-red-600 text-2xl font-bold">&times;</button>
            </div>
            <div id="cart-items" class="flex-1 p-6 overflow-y-auto space-y-4">
                <p class="text-gray-400 text-center mt-10">ตะกร้าของคุณยังว่างเปล่า</p>
            </div>
            <div class="p-6 border-t bg-gray-50">
                <div class="flex justify-between mb-4">
                    <span class="font-bold text-gray-600">ยอดรวมทั้งหมด:</span>
                    <span class="font-bold text-xl text-red-600" id="cart-total">฿0</span>
                </div>
                <button onclick="checkout()" class="w-full bg-red-600 text-white py-3 rounded-lg font-bold hover:bg-red-700 transition">
                    ดำเนินการชำระเงิน
                </button>
            </div>
        </div>
    </div>

    <script>
        let cart = [];

        function toggleCart() {
            const modal = document.getElementById('cart-modal');
            modal.classList.toggle('hidden');
        }

        function addToCart(id, name, price) {
            const existingItem = cart.find(item => item.id === id);
            if (existingItem) {
                existingItem.quantity += 1;
            } else {
                cart.push({ id, name, price, quantity: 1 });
            }
            updateCartUI();
            
            // แจ้งเตือนเมื่อหยิบใส่ตะกร้า
            alert(`เพิ่ม ${name} ลงในตะกร้าแล้ว`);
        }

        function removeFromCart(id) {
            cart = cart.filter(item => item.id !== id);
            updateCartUI();
        }

        function updateCartUI() {
            const cartItemsContainer = document.getElementById('cart-items');
            const cartTotalElement = document.getElementById('cart-total');
            const cartCountElements = [document.getElementById('cart-count'), document.getElementById('cart-count-mobile')];
            
            cartItemsContainer.innerHTML = '';
            let total = 0;
            let count = 0;

            if (cart.length === 0) {
                cartItemsContainer.innerHTML = '<p class="text-gray-400 text-center mt-10">ตะกร้าของคุณยังว่างเปล่า</p>';
            } else {
                cart.forEach(item => {
                    const itemTotal = item.price * item.quantity;
                    total += itemTotal;
                    count += item.quantity;

                    cartItemsContainer.innerHTML += `
                        <div class="flex justify-between items-center bg-white p-3 rounded border">
                            <div>
                                <h4 class="font-bold">${item.name}</h4>
                                <p class="text-sm text-gray-500">฿${item.price} x ${item.quantity}</p>
                            </div>
                            <div class="flex items-center gap-4">
                                <span class="font-bold text-red-600">฿${itemTotal}</span>
                                <button onclick="removeFromCart(${item.id})" class="text-red-400 hover:text-red-600 text-sm">ลบ</button>
                            </div>
                        </div>
                    `;
                });
            }

            cartTotalElement.innerText = `฿${total}`;
            cartCountElements.forEach(el => el.innerText = count);
        }

        function checkout() {
            if (cart.length === 0) {
                alert('ตะกร้าว่างเปล่าครับ กรุณาเลือกสินค้าก่อนทำการชำระเงิน');
                return;
            }
            // ในการใช้งานจริง สามารถลิงก์ไปยังหน้า LINE OA, ตะกร้า Shopee/Lazada หรือระบบ Payment Gateway ได้เลยครับ
            alert('ระบบกำลังพาท่านเข้าสู่หน้าชำระเงิน... (ส่วนนี้สามารถเชื่อมต่อกับ LINE หรือ Payment Gateway ได้ครับ)');
            cart = [];
            updateCartUI();
            toggleCart();
        }
    </script>
</body>
</html>
